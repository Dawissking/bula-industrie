# Variables d'environnement pour Bula Industrie
# Copiez ce fichier en .env.local et remplissez les valeurs

# URL du site en production (ex: https://bulaindustrie.com)
NEXT_PUBLIC_SITE_URL=

# Clé API pour le formulaire de contact (optionnel)
# CONTACT_API_KEY=

# Configuration email (optionnel, pour envoyer les messages)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
